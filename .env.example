# ── Database (XAMPP MySQL: root, no password) ──
DATABASE_URL=mysql+pymysql://root@localhost:3306/clipper

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_BACKEND=redis://localhost:6379/1

# ── Storage ──
STORAGE_ROOT=/opt/clipper/storage
COOKIES_PATH=/opt/clipper/cookies/tiktok_session.json
CLEANUP_AFTER_CLIP=true
DISK_WARN_PERCENT=85
CLIP_RETENTION_DAYS=30

# ── Whisper (transcription) ──
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=id

# ── FFmpeg (video processing) ──
FFMPEG_THREADS=2
FFMPEG_PRESET=fast
FFMPEG_CRF=23
VIDEO_MAX_HEIGHT=720

# ── Clipping ──
DEFAULT_CLIP_MIN_DURATION=60
DEFAULT_CLIP_MAX_DURATION=90

# ── AI / Groq (viral clip detection) ──
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_CLIP_ENABLED=true
AI_MIN_VIRAL_SCORE=7
DEFAULT_NICHE=finance

# ── TikTok ──
TIKTOK_UPLOAD_URL=https://www.tiktok.com/creator#/upload
TIKTOK_MAX_UPLOADS_PER_DAY=10
TIKTOK_DELAY_BETWEEN_UPLOADS_MIN=300
TIKTOK_DELAY_BETWEEN_UPLOADS_MAX=900
TIKTOK_AUTO_UPLOAD=false

# ── Celery ──
CELERY_CONCURRENCY=1
